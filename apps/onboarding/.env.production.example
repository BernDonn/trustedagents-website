# Trusted Agents onboarding production runtime env
# Copy to a local-only file on the server; never commit real values.

# Generate once with:
#   python -m trusted_agents_onboarding.crypto
TRUSTED_AGENTS_MASTER_KEY=PASTE_GENERATED_FERNET_KEY_HERE

# Persistent tenant/audit store location inside the container or mounted volume.
TRUSTED_AGENTS_DB=/data/onboarding.sqlite3

# Public HTTPS base URL used for Mollie redirects and webhooks.
TRUSTED_AGENTS_PUBLIC_BASE_URL=https://PASTE-YOUR-ONBOARDING-URL

# Payment provider and API credentials.
TRUSTED_AGENTS_PAYMENT_PROVIDER=mollie
TRUSTED_AGENTS_MOLLIE_API_KEY=live_PASTE_REAL_VALUE_HERE

# Optional: set an environment label for logs and future admin filtering.
TRUSTED_AGENTS_ENV=production
