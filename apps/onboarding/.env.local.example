# Copy to .env.local and fill in your own values.
# This file is safe to commit; .env.local is gitignored.

export TRUSTED_AGENTS_MASTER_KEY='PASTE_GENERATED_KEY_HERE'
export TRUSTED_AGENTS_DB='./data/onboarding.sqlite3'

# Payment provider
export TRUSTED_AGENTS_PAYMENT_PROVIDER='mollie'

# Public base URL that Mollie can reach for redirects + webhooks.
# For local testing, use a tunnel URL like https://your-subdomain.ngrok-free.app
export TRUSTED_AGENTS_PUBLIC_BASE_URL='https://YOUR-PUBLIC-URL'

# Mollie test API key (starts with test_)
export TRUSTED_AGENTS_MOLLIE_API_KEY='test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx'

# Optional override for local/mock testing only
# export TRUSTED_AGENTS_MOLLIE_API_BASE='https://api.mollie.com/v2'
