# Copy to terraform.tfvars and edit locally.
# Never commit terraform.tfvars.

project_name = "trusted-agents"
environment  = "staging"
location     = "fsn1"
server_type  = "cx33"

# Paste the public half of the admin SSH key here.
ssh_public_key = "ssh-ed25519 REPLACE_WITH_PUBLIC_KEY_ONLY trusted-agents-admin"

# Restrict admin access to known operator addresses/ranges.
admin_cidrs = [
  "REPLACE_WITH_OPERATOR_CIDR"
]

enable_backups     = true
agent_capacity_cap = 10
