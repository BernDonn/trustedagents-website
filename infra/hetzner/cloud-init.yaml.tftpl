#cloud-config
package_update: true
package_upgrade: true

packages:
  - ca-certificates
  - curl
  - gnupg
  - ufw
  - fail2ban
  - unattended-upgrades

write_files:
  - path: /opt/trusted-agents/README.md
    permissions: '0644'
    content: |
      Trusted Agents managed node
      Project: ${project_name}
      Environment: ${environment}
      Initial bot capacity cap: ${agent_capacity_cap}

      This node is prepared for Docker-based Trusted Agent workers.
      Do not store raw customer secrets in plain files.
  - path: /opt/trusted-agents/docker-compose.yml
    permissions: '0640'
    content: |
      services:
        reverse-proxy:
          image: caddy:2-alpine
          restart: unless-stopped
          volumes:
            - ./Caddyfile:/etc/caddy/Caddyfile:ro
            - caddy-data:/data
            - caddy-config:/config
          networks:
            - trusted-agents

        onboarding-backend:
          image: ghcr.io/berndonn/trusted-agents-onboarding:placeholder
          restart: unless-stopped
          environment:
            TRUSTED_AGENTS_ENV: ${environment}
            TRUSTED_AGENTS_CAPACITY_CAP: "${agent_capacity_cap}"
          networks:
            - trusted-agents

        agent-worker-template:
          image: ghcr.io/berndonn/trusted-agent-worker:placeholder
          restart: "no"
          profiles: ["template"]
          environment:
            TRUSTED_AGENTS_ENV: ${environment}
          networks:
            - trusted-agents

      networks:
        trusted-agents:
          name: trusted-agents

      volumes:
        caddy-data:
        caddy-config:
  - path: /opt/trusted-agents/Caddyfile
    permissions: '0640'
    content: |
      {
        auto_https off
      }

      :8080 {
        respond "Trusted Agents managed node is prepared"
      }

runcmd:
  - install -m 0755 -d /etc/apt/keyrings
  - curl -fsSL https://download.docker.com/linux/ubuntu/gpg | gpg --dearmor -o /etc/apt/keyrings/docker.gpg
  - chmod a+r /etc/apt/keyrings/docker.gpg
  - . /etc/os-release && echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.gpg] https://download.docker.com/linux/ubuntu $VERSION_CODENAME stable" > /etc/apt/sources.list.d/docker.list
  - apt-get update
  - apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
  - systemctl enable --now docker
  - usermod -aG docker root
  - systemctl enable --now fail2ban
  - ufw allow OpenSSH
  - ufw allow http
  - ufw allow https
  - ufw --force enable
  - cd /opt/trusted-agents && docker compose config >/opt/trusted-agents/compose.rendered.txt
  - echo "trusted-agents-ready" >/opt/trusted-agents/READY
